#!/bin/bash
set -euo pipefail

###############################################################################
# reinstall — Remote reinstall a host via EFI boot-next to USB installer.
###############################################################################

usage() {
    cat <<EOF
Usage: ./reinstall <hostname> [options]

Remotely trigger a Debian reinstall via efibootmgr --bootnext. Reboots the
target into the USB installer, waits for the install to complete, and verifies
the fresh system is up.

Requires: USB with preseed ISO plugged into the target host.

Options:
  -h, --help              Show this help message
  -n, --dry-run           Show what would happen without acting
  -y, --yes               Skip confirmation prompt
  -b, --boot-entry ENTRY  EFI boot entry for USB installer (auto-detected if omitted)
  -t, --timeout SECONDS   Max seconds to wait for host to return (default: 1200)

Environment variables (flags take precedence):
  REINSTALL_BOOT_ENTRY, REINSTALL_TIMEOUT

Examples:
  ./reinstall mother
  ./reinstall mother --yes
  ./reinstall mother --boot-entry 0005 --timeout 900
  ./reinstall mother --dry-run
EOF
    exit 0
}

# --- Parse flags ------------------------------------------------------------

DRY_RUN=false
YES=false
HOST=""

while [ $# -gt 0 ]; do
    case "$1" in
        -h|--help)       usage ;;
        -n|--dry-run)    DRY_RUN=true; shift ;;
        -y|--yes)        YES=true; shift ;;
        -b|--boot-entry) BOOT_ENTRY="$2"; shift 2 ;;
        -t|--timeout)    TIMEOUT="$2"; shift 2 ;;
        -*)              echo "ERROR: Unknown option: $1"; echo "Run ./reinstall --help for usage."; exit 1 ;;
        *)               HOST="$1"; shift ;;
    esac
done

BOOT_ENTRY="${BOOT_ENTRY:-${REINSTALL_BOOT_ENTRY:-}}"
TIMEOUT="${TIMEOUT:-${REINSTALL_TIMEOUT:-1200}}"
POLL_INTERVAL=15

if [ -z "$HOST" ]; then
    echo "ERROR: hostname required. Run ./reinstall --help for usage."
    exit 1
fi

# --- Dry run (boot entry known) --------------------------------------------

if $DRY_RUN && [ -n "$BOOT_ENTRY" ]; then
    cat <<EOF
Dry run — no changes will be made.

  Host:        $HOST
  Boot entry:  $BOOT_ENTRY
  Timeout:     ${TIMEOUT}s ($((TIMEOUT / 60))m)
  Yes:         $YES
EOF
    exit 0
fi

# --- SSH helpers ------------------------------------------------------------

ssh_to_host() {
    ssh -o ConnectTimeout=5 -o BatchMode=yes "$HOST" "$@"
}

ssh_to_fresh_host() {
    ssh -o ConnectTimeout=5 -o BatchMode=yes \
        -o StrictHostKeyChecking=no \
        -o UserKnownHostsFile=/dev/null \
        "$HOST" "$@"
}

# --- Step 1: Preflight ------------------------------------------------------

echo "=== Preflight: verifying $HOST is reachable ..."

if ! ssh_to_host "true" 2>/dev/null; then
    echo "ERROR: Cannot reach $HOST via SSH. Is the host running?"
    exit 1
fi
echo "    SSH connection OK"

if ! ssh_to_host "command -v efibootmgr >/dev/null" 2>/dev/null; then
    echo "ERROR: efibootmgr not found on $HOST. Install with: sudo apt install efibootmgr"
    exit 1
fi
echo "    efibootmgr found"

efi_output=$(ssh_to_host "sudo efibootmgr" 2>/dev/null)

# Auto-detect USB CDROM boot entry if not specified
if [ -z "$BOOT_ENTRY" ]; then
    BOOT_ENTRY=$(echo "$efi_output" | grep "USB.*PART 1" | grep -o "Boot[0-9A-Fa-f]*" | head -1 | sed 's/^Boot\*//' | sed 's/^Boot//')
    if [ -z "$BOOT_ENTRY" ]; then
        echo "ERROR: No USB installer (PART 1) detected on $HOST. Is a USB plugged in?"
        echo "       Available entries:"
        echo "$efi_output" | grep "^Boot" | sed 's/^/       /'
        exit 1
    fi
    echo "    Auto-detected boot entry: $BOOT_ENTRY"
fi

boot_label=$(echo "$efi_output" | grep "Boot${BOOT_ENTRY}" | head -1)

if [ -z "$boot_label" ]; then
    echo "ERROR: EFI boot entry $BOOT_ENTRY not found on $HOST. Available entries:"
    echo "$efi_output" | grep "^Boot" | sed 's/^/       /'
    exit 1
fi
echo "    $boot_label"

# --- Dry run ----------------------------------------------------------------

if $DRY_RUN; then
    cat <<EOF

Dry run — no changes will be made.

  Host:        $HOST
  Boot entry:  $BOOT_ENTRY ($boot_label)
  Timeout:     ${TIMEOUT}s ($((TIMEOUT / 60))m)
  Yes:         $YES
EOF
    exit 0
fi

# --- Step 2: Confirmation ---------------------------------------------------

if ! $YES; then
    echo ""
    echo "WARNING: This will wipe and reinstall $HOST via EFI boot entry $BOOT_ENTRY."
    echo ""
    read -rp "Type YES to proceed: " confirm
    if [ "$confirm" != "YES" ]; then
        echo "Aborted."
        exit 0
    fi
fi

# --- Step 3: Set boot-next + reboot ----------------------------------------

start_time=$(date +%s)

echo "=== Setting EFI boot-next to $BOOT_ENTRY and rebooting ..."
ssh_to_host "sudo efibootmgr --bootnext $BOOT_ENTRY" >/dev/null 2>&1
echo "    Boot-next set"
ssh_to_host "sudo systemctl reboot" 2>/dev/null || true
echo "    Reboot command sent"

# --- Step 4: Remove old host key -------------------------------------------

echo "=== Removing old host key for $HOST ..."
ssh-keygen -R "$HOST" 2>/dev/null || true

# --- Step 5: Poll for SSH --------------------------------------------------

echo "=== Waiting for $HOST to reinstall (timeout: $((TIMEOUT / 60))m) ..."

attempt=0
while true; do
    elapsed=$(( $(date +%s) - start_time ))
    if [ "$elapsed" -ge "$TIMEOUT" ]; then
        echo "ERROR: Timed out after ${TIMEOUT}s waiting for $HOST to come back."
        exit 1
    fi

    attempt=$((attempt + 1))
    remaining=$(( (TIMEOUT - elapsed) / 60 ))
    echo "    Attempt $attempt (${elapsed}s elapsed, ~${remaining}m remaining) ..."

    remote_uptime=$(ssh_to_fresh_host "cat /proc/uptime" 2>/dev/null | cut -d' ' -f1 | cut -d. -f1) || { sleep "$POLL_INTERVAL"; continue; }
    if [ "$remote_uptime" -lt 300 ] 2>/dev/null; then
        echo "    SSH is up! (uptime: ${remote_uptime}s)"
        break
    fi
    echo "    SSH responded but uptime is ${remote_uptime}s — not a fresh install, still waiting ..."

    sleep "$POLL_INTERVAL"
done

# --- Step 6: Verify fresh install ------------------------------------------

echo "=== Verifying fresh install on $HOST ..."

verify=$(ssh_to_fresh_host "hostname; uname -r; cat /proc/uptime; cat /var/log/installer/lsb-release; stat -c %Y /var/log/installer/" 2>/dev/null) || true

remote_hostname=$(echo "$verify" | sed -n '1p')
remote_kernel=$(echo "$verify" | sed -n '2p')
remote_uptime=$(echo "$verify" | sed -n '3p' | cut -d' ' -f1 | cut -d. -f1)
installer_release=$(echo "$verify" | grep "^DISTRIB_RELEASE=" | cut -d= -f2)
install_epoch=$(echo "$verify" | tail -1)
install_time=$(date -d "@$install_epoch" "+%Y-%m-%d %H:%M:%S" 2>/dev/null || echo "unknown")

echo "    Hostname:  $remote_hostname"
echo "    Kernel:    $remote_kernel"
echo "    Uptime:    ${remote_uptime}s"
echo "    Installer: $installer_release"
echo "    Installed: $install_time"

if [ "$remote_uptime" -gt 300 ] 2>/dev/null; then
    echo "WARNING: Uptime is ${remote_uptime}s (>5 min). This may not be a fresh install."
    echo "         Check that the USB installer was plugged in and EFI boot-next was set correctly."
fi

# --- Step 7: Accept host key ------------------------------------------------

ssh-keygen -R "$HOST" 2>/dev/null || true
ssh -o ConnectTimeout=5 -o BatchMode=yes -o StrictHostKeyChecking=accept-new "$HOST" "true" 2>/dev/null || true

# --- Step 8: Summary -------------------------------------------------------

elapsed=$(( $(date +%s) - start_time ))
printf "\n=== Reinstall complete. (%dm %ds)\n" $((elapsed / 60)) $((elapsed % 60))
echo "    ssh $HOST"
